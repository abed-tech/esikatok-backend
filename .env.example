# =============================================================================
# EsikaTok — Variables d'environnement
# Copier ce fichier vers .env et remplir les valeurs.
# NE JAMAIS commiter le fichier .env dans le dépôt Git.
# =============================================================================

# --- Environnement ---
# Valeurs : local, production
DJANGO_ENV=local

# --- Sécurité ---
# Générer avec : python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=CHANGEZ-MOI-avec-une-cle-secrete-longue-et-aleatoire

# --- Hôtes autorisés (séparés par des virgules) ---
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Base de données ---
# En local : laisser vide pour utiliser SQLite
# En production : PostgreSQL requis
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=5432

# --- CORS — Origines autorisées (séparés par des virgules) ---
# En local : http://localhost:3000,http://localhost:5173
# En production : https://esikatok.com,https://admin.esikatok.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# --- URLs publiques des services ---
# URL de base de l'API (vue par les frontends)
API_BASE_URL=http://localhost:8000
# URL du frontend utilisateur
FRONTEND_URL=http://localhost:8000
# URL du frontend administrateur
ADMIN_FRONTEND_URL=http://localhost:8000/gestion/EsikaTok
# URL publique des médias (CDN ou serveur de médias)
MEDIA_PUBLIC_URL=http://localhost:8000/media

# --- Stockage vidéo / médias ---
# Backend : local ou s3
STORAGE_BACKEND=local
# Configuration S3 (si STORAGE_BACKEND=s3)
VIDEO_S3_BUCKET=
VIDEO_S3_REGION=eu-west-1
VIDEO_S3_ACCESS_KEY=
VIDEO_S3_SECRET_KEY=
VIDEO_S3_ENDPOINT=
VIDEO_CDN_URL=

# --- E-mail ---
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# --- JWT ---
JWT_ACCESS_LIFETIME_MINUTES=30
JWT_REFRESH_LIFETIME_DAYS=7

# --- Chemin admin (URL secrète d'accès à l'admin) ---
ADMIN_PATH=gestion/EsikaTok
